{
  "name": "vite-vue-starter",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:github": "vue-tsc -b && vite build --mode github",
    "preview": "vite preview",
    "prepare": "husky",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "stylelint": "stylelint \"src/**/*.{css,scss,sass,vue,html}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss,sass,vue,html}\" --fix",
    "lint": "npm run eslint && npm run stylelint",
    "lint:fix": "npm run eslint:fix && npm run stylelint:fix"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.15.2",
    "element-plus": "^2.13.7",
    "fuse.js": "^7.3.0",
    "geed-storage": "^1.1.0",
    "jszip": "^3.10.1",
    "lodash-es": "^4.18.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-angular": "^20.5.0",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "autoprefixer": "^10.5.0",
    "code-inspector-plugin": "^1.5.1",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.12",
    "postcss-html": "^1.8.1",
    "postcss-nested": "^7.0.2",
    "sass-embedded": "^1.99.0",
    "simple-git": "^3.36.0",
    "stylelint": "^17.9.1",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-tailwindcss": "^0.0.7",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.2",
    "typescript": "~6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^7.3.1",
    "vite-plugin-inspect": "^11.3.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plugin-vue-inspector": "^5.4.0",
    "vue-click-to-component": "^0.3.8",
    "vue-tsc": "^3.2.7"
